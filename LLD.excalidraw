      "updated": 1773692642407,
      "link": null,
      "locked": false,
      "text": "this.BroadCastInfo({\n        type: \"RACE_UPDATE\",\n        payload: {\n          players: this.players.map(p => ({\n            userId: p.userId,\n            typedCharCount:\np.PlayerProgress.typedCharCount,\n            wpm: p.PlayerProgress.wpm,\n            acc:p.PlayerProgress.accuracy,\n            isFinished: p.PlayerProgress.isFinished,\n            RaceState:p.PlayerProgress.racePoints,\n          }))\n        }",
      "fontSize": 33.41274576505077,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
