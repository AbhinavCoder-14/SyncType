      "text": "Player {\n  userId: string;\n  ws: WebSocket;\n  name: string;\n  PlayerProgress: {\n    wpm: number;\n    accuracy: number;\n    isFinished: boolean;\n    finishTime: number | undefined;\n    typedCharCount: number;\n\n    typos: Set<string>;\n    totalKeystrokes: number; //\nNeeded for accurate Accuracy math\n    racePoints:number // final relative\nmarking\n  };\n  isStarted: boolean;\n\n}",
