      "updated": 1773569290015,
      "link": null,
      "locked": false,
      "text": "this.BroadCastInfo({\n        type: \"RACE_UPDATE\",\n        payload: {\n          players: this.players.map(p => ({\n            userId: p.userId,\n            typedCharCount: p.PlayerProgress.typedCharCount,\n            wpm: p.PlayerProgress.wpm,\n            acc:p.PlayerProgress.accuracy,\n            isFinished: p.PlayerProgress.isFinished,\n            RaceState:p.PlayerProgress.racePoints,\n          }))\n        }",
      "fontSize": 33.41274576505077,
      "fontFamily": 5,
      "textAlign": "center",
      "verticalAlign": "middle",
      "containerId": "t5J05l_SW98ut_1yNH6YF",
